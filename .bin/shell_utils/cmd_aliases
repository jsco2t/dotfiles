#
# colorized command output
#

# enable color support of ls and also add handy aliases
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
fi
export COLOR_MODE='--color=auto'
alias grep='grep ${COLOR_MODE}'
alias egrep='grep -E ${COLOR_MODE}'
alias fgrep='grep -F ${COLOR_MODE}'
alias zgrep='zgrep ${COLOR_MODE}'

#
# customized `ls` handling
#
alias ll='ls -l ${COLOR_MODE}'
alias ls='ls -laF ${COLOR_MODE}'
alias l='/bin/ls -F ${COLOR_MODE}'

#
# utility directory commands
#
alias home='cd ~ ; clear'
alias c='clear'

#
# handling md5 checks
#
if ! [ -x "$(command -v md5)" ]; then
    md5() { echo "$1" | md5sum | awk '{print $1}'; }
fi

